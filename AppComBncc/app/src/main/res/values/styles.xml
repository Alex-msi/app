<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTitleText">
        <item name="android:textColor">@color/text_primary_soft</item>
        <item name="android:textSize">@dimen/text_title_main</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SectionTitleText">
        <item name="android:textColor">@color/text_primary_soft</item>
        <item name="android:textSize">@dimen/text_title_section</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BodyText">
        <item name="android:textColor">@color/text_primary_soft</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <style name="SecondaryText">
        <item name="android:textColor">@color/text_secondary_soft</item>
        <item name="android:textSize">@dimen/text_secondary</item>
    </style>

    <style name="CardContainer">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>
</resources>
