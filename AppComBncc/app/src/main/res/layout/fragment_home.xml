<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_16">

        <ImageView
            android:id="@+id/homeLogoIv"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:adjustViewBounds="true"
            android:contentDescription="Logo AppBNCC Computação"
            android:scaleType="fitCenter"
            android:src="@mipmap/ic_banner_foreground" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:layout_marginBottom="@dimen/space_4"
            android:gravity="center"
            android:text="Selecione a etapa para iniciar a navegação."
            android:textAlignment="center"
            style="@style/SecondaryText" />

        <Button
            android:id="@+id/etapaEiBt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:minHeight="@dimen/button_min_height"
            android:text="Educação Infantil"
            android:textSize="@dimen/text_body"
            android:backgroundTint="@color/etapa_ei"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/etapaEfBt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:minHeight="@dimen/button_min_height"
            android:text="Ensino Fundamental"
            android:textSize="@dimen/text_body"
            android:backgroundTint="@color/etapa_ef"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/etapaEmBt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:minHeight="@dimen/button_min_height"
            android:text="Ensino Médio"
            android:textSize="@dimen/text_body"
            android:backgroundTint="@color/etapa_em"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_24"
            android:text="Busca de habilidade"
            style="@style/SectionTitleText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/buscaHabilidadeEt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Digite código ou descrição"
                android:inputType="text"
                android:minHeight="@dimen/button_min_height"
                android:textSize="@dimen/text_secondary" />

            <TextView
                android:id="@+id/procurarTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:clickable="true"
                android:focusable="true"
                android:minHeight="@dimen/button_min_height"
                android:gravity="center_vertical"
                android:text="Procurar"
                android:textColor="@color/mec_blue"
                android:textSize="@dimen/text_secondary"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/favoritosBt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:minHeight="@dimen/button_min_height"
            android:text="Favoritos"
            android:textSize="@dimen/text_body"
            android:backgroundTint="@color/mec_gray"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/pdfBnccBt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:minHeight="@dimen/button_min_height"
            android:text="PDF Computação Complemento a BNCC"
            android:textSize="@dimen/text_body"
            android:backgroundTint="@color/mec_gray"
            android:textColor="@android:color/white" />
    </LinearLayout>
</ScrollView>