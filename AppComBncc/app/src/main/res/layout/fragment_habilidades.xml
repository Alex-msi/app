<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_16">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detalhes da habilidade"
            style="@style/SectionTitleText" />

        <TextView
            android:id="@+id/codigoHabilidadeTv"
            style="@style/BodyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:text="Código:" />

        <TextView
            android:id="@+id/serieEtapaTv"
            style="@style/SecondaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="Série/Etapa:" />

        <TextView
            android:id="@+id/descricaoTv"
            style="@style/BodyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:text="Descrição:" />

        <Button
            android:id="@+id/expandirExplicacaoBt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:minHeight="@dimen/button_min_height"
            android:text="Expandir explicação"
            android:textSize="@dimen/text_body" />

        <TextView
            android:id="@+id/explicacaoTv"
            style="@style/BodyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="Explicação"
            android:visibility="gone" />

        <Button
            android:id="@+id/expandirExemploBt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:minHeight="@dimen/button_min_height"
            android:text="Expandir exemplo"
            android:textSize="@dimen/text_body" />

        <TextView
            android:id="@+id/exemploTv"
            style="@style/BodyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="Exemplo"
            android:visibility="gone" />

        <Button
            android:id="@+id/criarPraticaBt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:minHeight="@dimen/button_min_height"
            android:text="Criar prática"
            android:textSize="@dimen/text_body" />

        <ImageButton
            android:id="@+id/favoritarBt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:contentDescription="Favoritar habilidade"
            android:src="@android:drawable/btn_star_big_off" />
    </LinearLayout>
</ScrollView>










