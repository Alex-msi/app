<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tituloTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lista de Eixos/Competências" />

    <TextView
        android:id="@+id/subtituloTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="(cada item exibirá somente quantidade de habilidades)"
        android:textSize="12sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/eixoCompetenciaRv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp" />

        <Button
        android:id="@+id/continuarEixoBt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Abrir detalhe da habilidade" />

    </LinearLayout>