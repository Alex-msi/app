<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_16">

        <TextView
            android:id="@+id/tituloTelaTv"
            style="@style/AppTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/mec_blue"
            android:gravity="center"
            android:paddingVertical="@dimen/space_8"
            android:text="Prática Pedagógica"
            android:textColor="@color/white" />

        <com.google.android.material.card.MaterialCardView
            style="@style/CardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_16">

            <TextView
                style="@style/SectionTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dados da habilidade" />

            <TextView
                android:id="@+id/habilidadeTv"
                style="@style/BodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:text="Habilidade: -"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/descricaoTv"
                style="@style/BodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:text="Descrição: -" />

            <TextView
                android:id="@+id/serieTv"
                style="@style/BodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:text="Série: -" />

            <TextView
                style="@style/SecondaryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:text="Tempo" />

            <Spinner
                android:id="@+id/tempoSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:minHeight="@dimen/button_min_height" />

            <TextView
                style="@style/SecondaryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:text="Tipo" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/desplugadaCb"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="true"
                    android:minHeight="@dimen/button_min_height"
                    android:text="Desplugada" />

                <CheckBox
                    android:id="@+id/plugadaCb"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="@dimen/button_min_height"
                    android:text="Plugada" />
            </LinearLayout>

            <Button
                android:id="@+id/gerarComIaBt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:minHeight="@dimen/button_min_height"
                android:text="Gerar"
                android:textAllCaps="true" />

            <!--                <Button-->
            <!--                    android:id="@+id/gerarSemIaBt"-->
            <!--                    android:layout_width="0dp"-->
            <!--                    android:layout_height="wrap_content"-->
            <!--                    android:layout_marginStart="@dimen/space_12"-->
            <!--                    android:layout_weight="1"-->
            <!--                    android:minHeight="@dimen/button_min_height"-->
            <!--                    android:text="Criar sem IA"-->
            <!--                    android:textAllCaps="true" />-->
        </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/CardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_16">

            <TextView
                style="@style/SectionTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Plano da prática" />

            <EditText
                android:id="@+id/tituloPraticaEt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:hint="Título da prática"
                android:minHeight="@dimen/button_min_height" />

            <EditText
                android:id="@+id/objetivoEt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:gravity="top|start"
                android:hint="Objetivo"
                android:minHeight="80dp" />

            <EditText
                android:id="@+id/materiaisEt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:hint="Materiais"
                android:minHeight="@dimen/button_min_height" />

            <EditText
                android:id="@+id/introducaoEt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:hint="Introdução"
                android:minHeight="@dimen/button_min_height" />

            <EditText
                android:id="@+id/desenvolvimentoEt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:hint="Desenvolvimento"
                android:minHeight="@dimen/button_min_height" />

            <EditText
                android:id="@+id/praticaEt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:hint="Atividade Prática"
                android:minHeight="@dimen/button_min_height" />

            <EditText
                android:id="@+id/encerramentoEt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:hint="Encerramento"
                android:minHeight="@dimen/button_min_height" />

            <EditText
                android:id="@+id/statusEt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:hint="Status"
                android:minHeight="@dimen/button_min_height" />
        </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:orientation="vertical">

            <Button
                android:id="@+id/editarBt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/button_min_height"
                android:text="Editar" />

            <Button
                android:id="@+id/salvarBt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:minHeight="@dimen/button_min_height"
                android:text="Salvar" />

            <Button
                android:id="@+id/visualizarBt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:minHeight="@dimen/button_min_height"
                android:text="Visualizar" />

            <Button
                android:id="@+id/removerBt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:minHeight="@dimen/button_min_height"
                android:text="Remover" />

            <Button
                android:id="@+id/sairBt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:minHeight="@dimen/button_min_height"
                android:text="Sair" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
